# Copy this file to ".env" and fill in your real values.
# Never commit the real .env to git.

# Reddit account used by the Playwright browser session.
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# OpenAI key for relevance scoring and draft generation.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1-mini

# Optional log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Optional residential proxy. Leave PROXY_SERVER blank to run on the local
# connection. When set, every browser session routes through it. Use a sticky
# residential session in a geography that matches the account's usual location.
# PROXY_SERVER=http://gate.provider.com:7000
# PROXY_USERNAME=your_proxy_user
# PROXY_PASSWORD=your_proxy_pass
